

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  // url      = "file:dev.db"
}




model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?  @unique
  fullName  String
  password  String
  role      String   @default("USER") // ADMIN, DRIVER, USER
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
